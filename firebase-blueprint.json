{
  "entities": {
    "Project": {
      "title": "Portfolio Project",
      "description": "A project showcased on the portfolio website",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Title of the project"
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the project"
        },
        "category": {
          "type": "string",
          "enum": ["Web", "App"],
          "description": "Category of the project"
        },
        "techStack": {
          "type": "array",
          "description": "Array of technologies used"
        },
        "imageUrl": {
          "type": "string",
          "description": "Cloudinary secure image URL"
        },
        "videoUrl": {
          "type": "string",
          "description": "YouTube or Vimeo embed video URL"
        },
        "liveLink": {
          "type": "string",
          "description": "Live production website URL"
        },
        "apkLink": {
          "type": "string",
          "description": "Download link for the Android APK"
        },
        "guide": {
          "type": "string",
          "description": "Step-by-step user guide"
        },
        "versionLogs": {
          "type": "array",
          "description": "List of version updates/logs"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp"
        }
      },
      "required": ["title", "description", "category", "techStack", "imageUrl", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Contact Message",
      "description": "A contact submission form message from potential clients",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the sender"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the sender"
        },
        "message": {
          "type": "string",
          "description": "Message content"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Submission timestamp"
        }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of showcase projects managed by the admin"
    },
    "messages/{messageId}": {
      "schema": "Message",
      "description": "Inquiries and contact messages sent by clients"
    }
  }
}
