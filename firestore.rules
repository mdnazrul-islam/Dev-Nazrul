rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net catches all unspecified routes
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened security credentials and validation helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email == "nazrul.islam.uli019@gmail.com" &&
             request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Checks project structure, data types, and safety limits
    function isValidProject(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 10000 &&
             data.category is string && (data.category == "Web" || data.category == "App") &&
             data.techStack is list && data.techStack.size() <= 30 &&
             data.imageUrl is string && data.imageUrl.size() <= 2083 &&
             (data.videoUrl == null || (data.videoUrl is string && data.videoUrl.size() <= 2083)) &&
             (data.liveLink == null || (data.liveLink is string && data.liveLink.size() <= 2083)) &&
             (data.apkLink == null || (data.apkLink is string && data.apkLink.size() <= 2083)) &&
             (data.guide == null || (data.guide is string && data.guide.size() <= 10000)) &&
             (data.versionLogs == null || (data.versionLogs is list && data.versionLogs.size() <= 100));
    }

    // Form submission validation
    function isValidMessage(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 320 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 5000 &&
             data.createdAt == request.time;
    }

    // Projects: anyone can read, only admin can write
    match /projects/{projectId} {
      allow read: if true;
      allow create: if isAdmin() && 
                      isValidId(projectId) && 
                      isValidProject(incoming()) && 
                      incoming().createdAt == request.time && 
                      incoming().updatedAt == request.time;
                      
      allow update: if isAdmin() && 
                      isValidId(projectId) && 
                      isValidProject(incoming()) && 
                      incoming().updatedAt == request.time && 
                      incoming().createdAt == existing().createdAt;
                      
      allow delete: if isAdmin() && isValidId(projectId);
    }

    // Messages: public can create (contact-us form), only admin can read list/item or delete
    match /messages/{messageId} {
      allow create: if isValidId(messageId) && isValidMessage(incoming());
      allow read, update, delete: if isAdmin() && isValidId(messageId);
    }
  }
}
